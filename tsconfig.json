{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["src"],
  "compilerOptions": {
    "lib": ["es2024"],
    "target": "es2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "mocha", "chai", "sinon", "sinon-chai"],
    "declaration": true,
    "inlineSourceMap": true,
    "inlineSources": true
  }
}
